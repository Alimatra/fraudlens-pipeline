{
  "name": "PL_FraudLens_Ingestion",
  "properties": {
    "description": "Pipeline d'ingestion et d'orchestration du pipeline FraudLens - Bronze vers Gold",
    "activities": [
      {
        "name": "Copy_Raw_To_Bronze",
        "type": "Copy",
        "description": "Copie des fichiers sources bruts vers le conteneur raw du Data Lake",
        "typeProperties": {
          "source": {
            "type": "DelimitedTextSource"
          },
          "sink": {
            "type": "DelimitedTextSink",
            "storeSettings": {
              "type": "AzureBlobFSWriteSettings"
            }
          }
        },
        "inputs": [
          {
            "referenceName": "DS_Source_Transactions",
            "type": "DatasetReference"
          }
        ],
        "outputs": [
          {
            "referenceName": "DS_Raw_Transactions",
            "type": "DatasetReference"
          }
        ]
      },
      {
        "name": "Run_Bronze_Notebook",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "Copy_Raw_To_Bronze",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "typeProperties": {
          "notebookPath": "/Shared/fraudlens/01_bronze_ingestion"
        },
        "linkedServiceName": {
          "referenceName": "LS_AzureDatabricks",
          "type": "LinkedServiceReference"
        }
      },
      {
        "name": "Run_Silver_Notebook",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "Run_Bronze_Notebook",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "typeProperties": {
          "notebookPath": "/Shared/fraudlens/02_silver_transformation"
        },
        "linkedServiceName": {
          "referenceName": "LS_AzureDatabricks",
          "type": "LinkedServiceReference"
        }
      },
      {
        "name": "Run_Gold_Notebook",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "Run_Silver_Notebook",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "typeProperties": {
          "notebookPath": "/Shared/fraudlens/03_gold_aggregation"
        },
        "linkedServiceName": {
          "referenceName": "LS_AzureDatabricks",
          "type": "LinkedServiceReference"
        }
      }
    ],
    "annotations": ["fraudlens", "medallion-architecture"]
  }
}
